FROM lmsysorg/sglang:dev-cu13

ARG EFA_VERSION=1.47.0

RUN apt-get update && apt-get install -y --no-install-recommends \
      pciutils environment-modules tcl \
      libnl-3-dev libnl-route-3-dev \
  && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN cd /tmp \
  && curl -O https://s3-us-west-2.amazonaws.com/aws-efa-installer/aws-efa-installer-${EFA_VERSION}.tar.gz \
  && tar -xf aws-efa-installer-${EFA_VERSION}.tar.gz \
  && cd aws-efa-installer \
  && ./efa_installer.sh -y --skip-kmod -g \
  && rm -rf /tmp/aws-efa-installer*

ENV PATH="/opt/amazon/efa/bin:/opt/amazon/openmpi/bin:$PATH"
ENV LD_LIBRARY_PATH="/opt/amazon/ofi-nccl/lib:/opt/amazon/efa/lib:/opt/amazon/openmpi/lib:$LD_LIBRARY_PATH"

ENV FI_PROVIDER=efa
ENV FI_EFA_USE_DEVICE_RDMA=1

# Rebuild mooncake from latest source with -DUSE_EFA=ON
RUN pip uninstall -y mooncake-transfer-engine 2>/dev/null; \
    cd /tmp && \
    git clone --depth 1 https://github.com/kvcache-ai/Mooncake.git && \
    cd Mooncake && \
    bash dependencies.sh && \
    mkdir -p build && cd build && \
    cmake .. -DUSE_HTTP=ON -DUSE_MNNVL=ON -DUSE_CUDA=ON -DWITH_EP=ON -DUSE_EFA=ON && \
    make -j4 && \
    make install && \
    rm -rf /tmp/Mooncake

# Patch: support SGLANG_MOONCAKE_TRANSPORT_PROTOCOL for EFA
COPY sglang/python/sglang/srt/environ.py /tmp/patch_environ.py
COPY sglang/python/sglang/srt/distributed/device_communicators/mooncake_transfer_engine.py /tmp/patch_mooncake_te.py
RUN SITE=$(python3 -c "import sglang, os; print(os.path.dirname(sglang.__file__))") && \
    cp /tmp/patch_environ.py "$SITE/srt/environ.py" && \
    cp /tmp/patch_mooncake_te.py "$SITE/srt/distributed/device_communicators/mooncake_transfer_engine.py" && \
    rm /tmp/patch_environ.py /tmp/patch_mooncake_te.py
